            { "id": "c1-chain", "label": "כלל השרשרת", "latex": "\\frac{d}{dx}f(g(x)) = f'(g(x))\\,g'(x)", "category": "theorem", "tags": ["derivative", "chain"], "difficulty": 2 },
            { "id": "c1-ln", "label": "נגזרת לוגריתם", "latex": "\\frac{d}{dx}\\ln x = \\frac{1}{x}", "category": "equation", "tags": ["derivative", "ln"], "difficulty": 1 }
