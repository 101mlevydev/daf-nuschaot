      "topics": [
        {
          "id": "la-determinants",
          "name": "דטרמיננטות",
          "formulas": [
            { "id": "la-det-2x2", "label": "דטרמיננטה 2×2", "latex": "\\det\\begin{pmatrix} a & b \\\\ c & d \\end{pmatrix} = ad - bc", "category": "equation", "tags": ["det", "matrix"], "difficulty": 1 },
            { "id": "la-det-product", "label": "כפליות הדטרמיננטה", "latex": "\\det(AB) = \\det(A)\\,\\det(B)", "category": "theorem", "tags": ["det", "product"], "difficulty": 2 },
            { "id": "la-cramer", "label": "כלל קרמר", "latex": "x_i = \\frac{\\det(A_i)}{\\det(A)}", "category": "theorem", "tags": ["cramer", "system"], "difficulty": 2 },
            { "id": "la-det-eigen", "label": "דטרמיננטה כמכפלת ע\"ע", "latex": "\\det(A) = \\prod_{i} \\lambda_i", "category": "theorem", "tags": ["det", "eigenvalue"], "difficulty": 3 }
          ]
        },
        {
          "id": "la-eigen",
          "name": "ערכים ווקטורים עצמיים",
          "formulas": [
            { "id": "la-char-poly", "label": "פולינום אופייני", "latex": "\\det(A - \\lambda I) = 0", "category": "equation", "tags": ["eigenvalue", "determinant"], "difficulty": 2 },
            { "id": "la-eigen-eq", "label": "משוואת הערך העצמי", "latex": "A\\vec{v} = \\lambda \\vec{v}", "category": "definition", "tags": ["eigenvalue", "eigenvector"], "difficulty": 1 },
            { "id": "la-trace-eigen", "label": "עקבה כסכום ע\"ע", "latex": "\\operatorname{tr}(A) = \\sum_{i} \\lambda_i", "category": "theorem", "tags": ["trace", "eigenvalue"], "difficulty": 2 },
            { "id": "la-diagonalize", "label": "לכסון מטריצה", "latex": "A = P D P^{-1}", "category": "theorem", "tags": ["diagonalization"], "difficulty": 3 }
          ]
        },
        {
          "id": "la-matrix-algebra",
          "name": "אלגברה של מטריצות",
          "formulas": [
            { "id": "la-inverse", "label": "מטריצה הופכית", "latex": "A^{-1} = \\frac{1}{\\det A}\\,\\operatorname{adj}(A)", "category": "equation", "tags": ["inverse", "adjugate"], "difficulty": 2 },
            { "id": "la-transpose-product", "label": "שחלוף של מכפלה", "latex": "(AB)^{T} = B^{T} A^{T}", "category": "theorem", "tags": ["transpose"], "difficulty": 1 },
            { "id": "la-inverse-product", "label": "הופכי של מכפלה", "latex": "(AB)^{-1} = B^{-1} A^{-1}", "category": "theorem", "tags": ["inverse"], "difficulty": 2 },
            { "id": "la-rank-nullity", "label": "משפט הדרגה", "latex": "\\dim(\\ker A) + \\operatorname{rank}(A) = n", "category": "theorem", "tags": ["rank", "kernel"], "difficulty": 3 }
          ]
        },
        {
          "id": "la-inner-product",
          "name": "מכפלה פנימית ונורמה",
          "formulas": [
            { "id": "la-dot", "label": "מכפלה סקלרית", "latex": "\\vec{u}\\cdot\\vec{v} = \\sum_{i=1}^{n} u_i v_i", "category": "definition", "tags": ["dot", "inner"], "difficulty": 1 },
            { "id": "la-norm", "label": "נורמה של וקטור", "latex": "\\lVert \\vec{v} \\rVert = \\sqrt{\\vec{v}\\cdot\\vec{v}}", "category": "definition", "tags": ["norm"], "difficulty": 1 },
            { "id": "la-cauchy-schwarz", "label": "אי-שוויון קושי-שוורץ", "latex": "|\\vec{u}\\cdot\\vec{v}| \\le \\lVert\\vec{u}\\rVert\\,\\lVert\\vec{v}\\rVert", "category": "theorem", "tags": ["inequality"], "difficulty": 2 },
            { "id": "la-projection", "label": "היטל וקטור", "latex": "\\operatorname{proj}_{\\vec{u}}\\vec{v} = \\frac{\\vec{u}\\cdot\\vec{v}}{\\vec{u}\\cdot\\vec{u}}\\,\\vec{u}", "category": "equation", "tags": ["projection"], "difficulty": 2 }
          ]
        }
      ]
    },
